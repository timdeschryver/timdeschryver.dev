{
	"name": "timdeschryver.dev",
	"author": "Tim Deschryver",
	"description": "timdeschryver.dev",
	"version": "0.0.1",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@10.33.2",
	"engines": {
		"node": "^24.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"prebuild": "rimraf build && pnpm copy:content",
		"build": "vite build",
		"preview": "vite preview",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:unit": "vitest",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"copy:content": "pnpm copy:blog && pnpm copy:bits",
		"copy:blog": "cpy 'blog/**/*.*' '!blog/**/*.md' 'static/blog'",
		"copy:bits": "cpy 'bits/**/*.*' '!bits/**/*.md' 'static/bits'",
		"g": "node ./scripts/generate",
		"gb": "node ./scripts/generate-bit",
		"p": "node ./scripts/devto",
		"banners": "node ./scripts/banners.js",
		"pre-commit": "pnpm banners && git add ./**/banner.png && lint-staged",
		"optimize:image": "node ./scripts/optimize-image-cli.js",
		"optimize:images": "node ./scripts/optimize-images.js",
		"contributors": "node ./scripts/contributors.js",
		"postinstall": "svelte-kit sync",
		"prepare": "git config core.hookspath .githooks"
	},
	"devDependencies": {
		"@azure/identity": "^4.13.0",
		"@azure/playwright": "^1.1.2",
		"@azure/static-web-apps-cli": "^2.0.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/hubot-sans": "^5.2.8",
		"@fontsource-variable/mona-sans": "^5.2.8",
		"@fontsource-variable/victor-mono": "^5.2.8",
		"@playwright/test": "^1.58.2",
		"@squoosh/lib": "0.5.3",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.2.9",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/adapter-vercel": "^6.0.0",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@testing-library/svelte": "5.3.1",
		"@types/marked": "6.0.0",
		"@types/node": "^24.0.0",
		"@typescript-eslint/eslint-plugin": "8.59.0",
		"@typescript-eslint/parser": "8.59.0",
		"axe-playwright": "2.2.2",
		"canvas-confetti": "1.9.4",
		"cpy-cli": "7.0.0",
		"dotenv": "^17.4.2",
		"dotenv-extended": "3.1.0",
		"eslint": "10.2.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"front-matter": "4.0.2",
		"globals": "^17.4.0",
		"jsdom": "29.1.0",
		"lint-staged": "16.4.0",
		"marked": "18.0.2",
		"node-fetch": "3.3.2",
		"playwright": "1.59.1",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.1",
		"rimraf": "6.1.3",
		"shiki": "1.29.2",
		"svelte": "5.55.4",
		"svelte-check": "4.4.6",
		"svelte-eslint-parser": "^1.6.0",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.58.1",
		"vite": "8.0.10",
		"vite-plugin-restart": "2.0.0",
		"vite-svg-loader": "5.1.1",
		"vitest": "2.1.9"
	}
}
